# AntaresOS · Ghostty — Matrix

font-family = "FiraCode Nerd Font"
font-size = 14
font-thicken = true

background = 000000
foreground = 00ff41
cursor-color = 00ff41
cursor-text = 000000
selection-background = 14371f
selection-foreground = 7cffa0

# Matrix palette (green base + accents)
palette = 0=#0b140b
palette = 1=#ff4d4d
palette = 2=#00ff41
palette = 3=#f5d76e
palette = 4=#35c9ff
palette = 5=#ff6fd8
palette = 6=#48ffe0
palette = 7=#7cffa0
palette = 8=#2e6b3e
palette = 9=#ff6b6b
palette = 10=#5cff77
palette = 11=#ffe58a
palette = 12=#7fdcff
palette = 13=#ff9be6
palette = 14=#8affea
palette = 15=#c8ffd4

background-opacity = 0.95
background-blur-radius = 20
minimum-contrast = 1.1
bold-is-bright = true

window-padding-x = 12
window-padding-y = 12
window-decoration = true
macos-titlebar-style = tabs
window-save-state = always

cursor-style = block
cursor-style-blink = true
shell-integration = zsh
shell-integration-features = cursor,sudo,title

mouse-hide-while-typing = true
copy-on-select = clipboard
confirm-close-surface = false
scrollback-limit = 100000

keybind = cmd+enter=toggle_fullscreen
keybind = cmd+k=clear_screen
