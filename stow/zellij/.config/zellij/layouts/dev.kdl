// AntaresOS · layout "dev" — edit | term | lib

layout {
    default_tab_template {
        pane size=1 borderless=true {
            plugin location="zellij:tab-bar"
        }
        children
        pane size=2 borderless=true {
            plugin location="zellij:status-bar"
        }
    }

    tab name="edit" focus=true {
        pane name="editor" {
            command "nvim"
            args "."
        }
    }

    tab name="term" {
        pane split_direction="vertical" {
            pane name="term-1"
            pane name="term-2"
        }
    }

    tab name="lib" {
        pane split_direction="vertical" {
            pane size="70%" name="library" {
                command "zsh"
                args "-ic" "cd $ANTARES_LIB && nvim ."
            }
            pane size="30%" name="search" {
                command "zsh"
                args "-ic" "cd $ANTARES_LIB; exec zsh"
            }
        }
    }
}
